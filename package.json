{
  "name": "claude-task-router",
  "version": "0.1.0",
  "description": "Automatically classify, optimize, and route Claude Code prompts to the right model and effort level — via a UserPromptSubmit hook or a pre-execution wrapper.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "hook",
    "router",
    "task-router",
    "model-routing",
    "prompt-optimization",
    "developer-tools",
    "ai"
  ],
  "homepage": "https://github.com/andrewpaul004/claude-task-router#readme",
  "bugs": {
    "url": "https://github.com/andrewpaul004/claude-task-router/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewpaul004/claude-task-router.git"
  },
  "license": "MIT",
  "author": "Your Name <you@example.com>",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "bin": {
    "claude-task-router": "dist/cli/index.js",
    "ctr": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "eval": "npm run build && node dist/cli/index.js eval",
    "benchmark": "npm run build && node dist/cli/index.js benchmark",
    "package:check": "npm run build && npm pack --dry-run",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run format:check && npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "env-paths": "^3.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.5",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
